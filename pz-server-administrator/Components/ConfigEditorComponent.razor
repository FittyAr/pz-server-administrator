@using Microsoft.FluentUI.AspNetCore.Components
@using pz_server_administrator.Models
@using pz_server_administrator.Services
@inject IPzServerService PzServerService
@inject IToastService ToastService

<FluentStack Orientation="Orientation.Vertical" VerticalGap="15">
    <FluentCard Style="padding: 10px; width: 100%;">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="10"
            VerticalAlignment="VerticalAlignment.Center">
            <FluentToolbar Style="flex-grow: 1;">
                <FluentButton IconStart="@(new Icons.Regular.Size16.Options())"
                    Appearance="@(_editMode == EditMode.Simple ? Appearance.Accent : Appearance.Stealth)"
                    OnClick="@(() => _editMode = EditMode.Simple)">Simple</FluentButton>
                <FluentButton IconStart="@(new Icons.Regular.Size16.Code())"
                    Appearance="@(_editMode == EditMode.Advanced ? Appearance.Accent : Appearance.Stealth)"
                    OnClick="@(() => _editMode = EditMode.Advanced)">Avanzado</FluentButton>
                <FluentDivider Role="DividerRole.Separator" Orientation="Orientation.Vertical" />
                <FluentButton IconStart="@(new Icons.Regular.Size16.Save())" Appearance="Appearance.Accent"
                    OnClick="SaveAsync">
                    Guardar</FluentButton>
                <FluentButton IconStart="@(new Icons.Regular.Size16.ArrowCounterclockwise())" OnClick="LoadAsync">
                    Recargar
                </FluentButton>
            </FluentToolbar>

            @if (_editMode == EditMode.Simple)
            {
                <FluentSearch @bind-Value="_searchText" Placeholder="Buscar configuración..." Style="width: 300px;"
                    Immediate="true" />
            }
        </FluentStack>
    </FluentCard>

    @if (_isBusy)
    {
        <FluentProgressRing />
    }
    else if (_config != null)
    {
        @if (_editMode == EditMode.Simple)
        {
            <FluentTabs Style="width: 100%; border: 1px solid var(--neutral-stroke-rest); border-radius: 8px; padding: 10px;">
                @foreach (var categoryGroup in GroupedEntries)
                {
                    <FluentTab Label="@categoryGroup.Key" IconStart="@GetCategoryIcon(categoryGroup.Key)">
                        <div style="max-height: calc(100vh - 350px); overflow-y: auto; padding: 15px; margin-top: 10px;">
                            <FluentGrid Spacing="3">
                                @foreach (var entry in categoryGroup.Value)
                                {
                                    <FluentGridItem xs="12" sm="6" md="4" lg="3">
                                        <FluentCard
                                            Style="padding: 12px; height: 100%; display: flex; flex-direction: column; border-top: 3px solid var(--accent-fill-rest); transition: transform 0.2s;"
                                            class="config-card">
                                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="5">
                                                <FluentLabel Typo="Typography.Body"
                                                    Style="font-weight: bold; color: var(--neutral-foreground-hint); text-transform: uppercase; font-size: 0.8em;">
                                                    @entry.Key
                                                </FluentLabel>

                                                <div style="padding: 5px 0;">
                                                    @if (entry.Type == "Boolean")
                                                    {
                                                        <FluentCheckbox Value="@GetBoolValue(entry)"
                                                            ValueChanged="@(v => SetBoolValue(entry, v))"
                                                            Label="@(string.IsNullOrEmpty(entry.Description) ? "Activar" : entry.Description)" />
                                                    }
                                                    else if (entry.Type == "Integer" || entry.Type == "Float")
                                                    {
                                                        <FluentNumberField TValue="double" Value="@GetDoubleValue(entry)"
                                                            ValueChanged="@(v => SetDoubleValue(entry, v))" Placeholder="@entry.Key"
                                                            FullWidth="true" />
                                                    }
                                                    else
                                                    {
                                                        <FluentTextField @bind-Value="@entry.Value" Placeholder="@entry.Key"
                                                            FullWidth="true" />
                                                    }
                                                </div>

                                                @if (!string.IsNullOrEmpty(entry.Description) && entry.Type != "Boolean")
                                                {
                                                    <FluentLabel Typo="Typography.Body"
                                                        Style="font-style: italic; opacity: 0.8; font-size: 0.85em;">
                                                        @entry.Description
                                                    </FluentLabel>
                                                }
                                            </FluentStack>
                                        </FluentCard>
                                    </FluentGridItem>
                                }
                            </FluentGrid>
                        </div>
                    </FluentTab>
                }
            </FluentTabs>
        }
        else
        {
            <FluentCard Style="padding: 0; overflow: hidden; height: calc(100vh - 300px); min-height: 500px;">
                <FluentTextArea @bind-Value="@_rawContent"
                    Style="width: 100%; height: 100%; font-family: 'Cascadia Code', 'Fira Code', monospace; font-size: 14px; border: none; padding: 15px; resize: none;"
                    Rows="40" />
            </FluentCard>
        }
    }
</FluentStack>

@code {
    [Parameter] public string? FilePath { get; set; }

    private PzConfig? _config;
    private string _rawContent = string.Empty;
    private string _searchText = string.Empty;
    private EditMode _editMode = EditMode.Simple;
    private bool _isBusy = false;

    private IEnumerable<PzConfigEntry> FilteredEntries => _config?.Entries
    .Where(e => string.IsNullOrEmpty(_searchText) ||
    e.Key.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
    e.Description.Contains(_searchText, StringComparison.OrdinalIgnoreCase)) ?? Enumerable.Empty<PzConfigEntry>();

    private Dictionary<string, List<PzConfigEntry>> GroupedEntries => FilteredEntries
    .GroupBy(e => GetCategory(e.Key))
    .ToDictionary(g => g.Key, g => g.ToList());

    private string GetCategory(string key)
    {
        if (key.Contains("PVP") || key.Contains("Safehouse")) return "PVP & Combat";
        if (key.Contains("RCON") || key.Contains("Host") || key.Contains("Port") || key.Contains("UPnP")) return "Network";
        if (key.Contains("Chat") || key.Contains("Message") || key.Contains("Voice")) return "Social";
        if (key.Contains("Map") || key.Contains("Spawn") || key.Contains("Region")) return "World";
        if (key.Contains("Mod") || key.Contains("Workshop")) return "Mods";
        if (key.Contains("Database") || key.Contains("Log") || key.Contains("Backup")) return "System";
        if (key.Contains("Zombie") || key.Contains("Loot")) return "Gameplay";

        // Use prefix as category if none of the above matches
        var parts = key.Split('_', 2);
        if (parts.Length > 1 && parts[0].Length > 2) return parts[0];

        return "General";
    }

    private Icon GetCategoryIcon(string category) => category switch
    {
        "PVP & Combat" => new Icons.Regular.Size16.Shield(),
        "Network" => new Icons.Regular.Size16.Globe(),
        "Social" => new Icons.Regular.Size16.Chat(),
        "World" => new Icons.Regular.Size16.Map(),
        "Mods" => new Icons.Regular.Size16.PuzzlePiece(),
        "System" => new Icons.Regular.Size16.Settings(),
        "Gameplay" => new Icons.Regular.Size16.VehicleBicycle(), // Closest to gameplay/movement icon
        _ => new Icons.Regular.Size16.Window()
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(FilePath))
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(FilePath)) return;

        _isBusy = true;
        try
        {
            _config = await PzServerService.ParseConfigAsync(FilePath);
            _rawContent = await PzServerService.ReadFileContentAsync(FilePath);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrEmpty(FilePath)) return;

        _isBusy = true;
        try
        {
            if (_editMode == EditMode.Simple && _config != null)
            {
                await PzServerService.SaveConfigAsync(_config);
                _rawContent = await PzServerService.ReadFileContentAsync(FilePath);
            }
            else
            {
                await PzServerService.SaveFileContentAsync(FilePath, _rawContent);
                _config = await PzServerService.ParseConfigAsync(FilePath);
            }
            ToastService.ShowSuccess("Configuración guardada correctamente.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al guardar: {ex.Message}");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private bool GetBoolValue(PzConfigEntry entry)
    {
        return bool.TryParse(entry.Value, out var val) && val;
    }

    private void SetBoolValue(PzConfigEntry entry, bool val)
    {
        entry.Value = val.ToString().ToLower();
    }

    private double GetDoubleValue(PzConfigEntry entry)
    {
        return double.TryParse(entry.Value, out var val) ? val : 0;
    }

    private void SetDoubleValue(PzConfigEntry entry, double val)
    {
        entry.Value = val.ToString();
    }

    private enum EditMode { Simple, Advanced }
}
