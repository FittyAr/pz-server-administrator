@page "/setup"
@layout SetupLayout
@using pz_server_administrator.Models
@using pz_server_administrator.Services
@inject IConfigurationService ConfigService
@inject IAuthenticationService AuthService
@inject ILocalizationService LocService
@inject IPzServerService PzServer
@inject IToastService ToastService
@inject NavigationManager NavManager

<div class="setup-container">
    <FluentCard Style="width: 800px; padding: 2.5rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
        <FluentStack Orientation="Orientation.Vertical" Spacing="5">

            @* HEADER *@
            <FluentStack VerticalAlignment="VerticalAlignment.Center" Spacing="3">
                <FluentIcon Value="@(new Icons.Regular.Size32.Box())" Color="Color.Accent" />
                <div>
                    <FluentLabel Typo="Typography.H3" Style="margin: 0;">Bienvenido a PZ Server Admin</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Configura tu servidor en unos simples
                        pasos</FluentLabel>
                </div>
            </FluentStack>

            <FluentDivider Style="width: 100%;" />

            @* STEPS INDICATOR *@
            <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Spacing="5" Style="padding: 1rem 0;">
                <div style="text-align: center; opacity: @(_currentStep == 0 ? "1" : "0.4")">
                    <FluentIcon Value="@(new Icons.Filled.Size24.Person())"
                        Color="@(_currentStep >= 0 ? Color.Accent : Color.Neutral)" />
                    <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; opacity: 0.8;">Admin</FluentLabel>
                </div>
                <FluentDivider Style="width: 50px; margin-top: 12px;" />
                <div style="text-align: center; opacity: @(_currentStep == 1 ? "1" : "0.4")">
                    <FluentIcon Value="@(new Icons.Filled.Size24.Server())"
                        Color="@(_currentStep >= 1 ? Color.Accent : Color.Neutral)" />
                    <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; opacity: 0.8;">Servidor</FluentLabel>
                </div>
                <FluentDivider Style="width: 50px; margin-top: 12px;" />
                <div style="text-align: center; opacity: @(_currentStep == 2 ? "1" : "0.4")">
                    <FluentIcon Value="@(new Icons.Filled.Size24.Wand())"
                        Color="@(_currentStep >= 2 ? Color.Accent : Color.Neutral)" />
                    <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; opacity: 0.8;">IA</FluentLabel>
                </div>
                <FluentDivider Style="width: 50px; margin-top: 12px;" />
                <div style="text-align: center; opacity: @(_currentStep == 3 ? "1" : "0.4")">
                    <FluentIcon Value="@(new Icons.Filled.Size24.CheckmarkCircle())"
                        Color="@(_currentStep >= 3 ? Color.Accent : Color.Neutral)" />
                    <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; opacity: 0.8;">Listo</FluentLabel>
                </div>
            </FluentStack>

            @* STEP CONTENT *@
            <div style="min-height: 400px; padding: 1rem 0;">
                @if (_currentStep == 0)
                {
                    <FluentStack Orientation="Orientation.Vertical" Spacing="4">
                        <FluentLabel Typo="Typography.H4">Cuenta de Administrador</FluentLabel>
                        <p>Crea el primer usuario con permisos totales para gestionar la plataforma.</p>
                        <FluentTextField @bind-Value="_adminUser" Label="Usuario" Placeholder="admin"
                            Style="width: 100%;" />
                        <FluentTextField @bind-Value="_adminPass" Label="Contraseña" Type="TextFieldType.Password"
                            Style="width: 100%;" />
                        <FluentTextField @bind-Value="_adminPassConfirm" Label="Confirmar Contraseña"
                            Type="TextFieldType.Password" Style="width: 100%;" />
                    </FluentStack>
                }
                else if (_currentStep == 1)
                {
                    <FluentStack Orientation="Orientation.Vertical" Spacing="4">
                        <FluentLabel Typo="Typography.H4">Configuración del Servidor</FluentLabel>
                        <p>Dinos dónde están los archivos de tu servidor Project Zomboid.</p>

                        <FluentTextField @bind-Value="_config.AppSettings.ServerDirectoryPath" Label="Ruta Base de Zomboid"
                            Placeholder="C:\Users\...\Zomboid" Style="width: 100%;" />
                        <FluentTextField @bind-Value="_config.AppSettings.ServerIniPath" Label="Archivo .INI Principal"
                            Placeholder="servertest.ini" Style="width: 100%;" />

                        <FluentButton IconStart="@(new Icons.Regular.Size20.Search())" OnClick="AutoDetect"
                            Loading="_isScanning">
                            Intentar autodetección
                        </FluentButton>

                        <p style="font-size: 0.8rem; opacity: 0.6;">Tip: Generalmente se encuentran en la carpeta de usuario
                            dentro de Zomboid/Server.</p>
                    </FluentStack>
                }
                else if (_currentStep == 2)
                {
                    <FluentStack Orientation="Orientation.Vertical" Spacing="4">
                        <FluentLabel Typo="Typography.H4">Inteligencia Artificial (Opcional)</FluentLabel>
                        <p>Habilita el Agente Inteligente para reparar errores automáticamente y optimizar el orden de mods.
                        </p>

                        <FluentSelect Label="Proveedor" Items="@_aiProviders" @bind-Value="_aiProviderString" />
                        <FluentTextField @bind-Value="_config.Ai.ApiKey" Label="API Key" Type="TextFieldType.Password"
                            Placeholder="Opcional, puedes configurarlo luego" Style="width: 100%;" />

                        <FluentCheckbox @bind-Value="_config.Ai.AiAutoFixEnabled"
                            Label="Habilitar reparación automática de conflictos" />
                    </FluentStack>
                }
                else if (_currentStep == 3)
                {
                    <FluentStack Orientation="Orientation.Vertical" Spacing="4"
                        HorizontalAlignment="HorizontalAlignment.Center" Style="text-align: center;">
                        <FluentIcon Value="@(new Icons.Regular.Size32.CheckmarkCircle())" Color="Color.Success"
                            Style="width: 64px; height: 64px;" />
                        <FluentLabel Typo="Typography.H3">¡Todo listo!</FluentLabel>
                        <p>La configuración básica se ha completado. Podrás ajustar más detalles en la página de
                            Configuración Global.</p>
                        <p>Haz clic en "Comenzar" para entrar a la plataforma.</p>
                    </FluentStack>
                }
            </div>

            @* NAVIGATION *@
            <FluentStack HorizontalAlignment="HorizontalAlignment.Right" Spacing="3">
                @if (_currentStep > 0 && _currentStep < 3)
                {
                    <FluentButton OnClick="PrevStep">Anterior</FluentButton>
                }

                @if (_currentStep < 3)
                {
                    <FluentButton Appearance="Appearance.Accent" OnClick="NextStep">Siguiente</FluentButton>
                }
                else
                {
                    <FluentButton Appearance="Appearance.Accent" OnClick="FinishSetup">Comenzar</FluentButton>
                }

                @if (_currentStep == 0)
                {
                    <FluentButton Appearance="Appearance.Neutral" OnClick="SkipSetup" Style="margin-right: auto;">Omitir
                        Asistente</FluentButton>
                }
            </FluentStack>

        </FluentStack>
    </FluentCard>
</div>

<style>
    .setup-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background: radial-gradient(circle at top right, #1a1a2e 0%, #0f0f1b 100%);
    }
</style>

@code {
    private int _currentStep = 0;
    private string _adminUser = "admin";
    private string _adminPass = "";
    private string _adminPassConfirm = "";
    private ZsmConfiguration _config = new();
    private bool _isScanning;

    private string _aiProviderString
    {
        get => _config.Ai.Provider.ToString();
        set => _config.Ai.Provider = Enum.Parse<AiProviderType>(value);
    }

    private AiProviderType[] _aiProviders = (AiProviderType[])Enum.GetValues(typeof(AiProviderType));

    protected override void OnInitialized()
    {
        _config = ConfigService.GetConfiguration();
    }

    private async Task NextStep()
    {
        if (_currentStep == 0)
        {
            if (string.IsNullOrWhiteSpace(_adminPass) || _adminPass != _adminPassConfirm)
            {
                ToastService.ShowError("Las contraseñas no coinciden o están vacías.");
                return;
            }
        }

        _currentStep++;
    }

    private void PrevStep() => _currentStep--;

    private async Task AutoDetect()
    {
        _isScanning = true;
        var success = await PzServer.AutoConfigureAsync();
        if (success)
        {
            _config = ConfigService.GetConfiguration();
            ToastService.ShowSuccess("Detección exitosa.");
        }
        else
        {
            ToastService.ShowWarning("No pudimos detectar todo automáticamente.");
        }
        _isScanning = false;
    }

    private async Task FinishSetup()
    {
        // 1. Guardar primero la configuración técnica (AI, Rutas)
        // Usamos el objeto _config que tiene los cambios del wizard
        await ConfigService.SaveConfigurationAsync(_config);

        // 2. Crear el usuario administrador SEGUNDO
        // Esto añadirá el usuario al archivo que acabamos de guardar
        await AuthService.CreateUserAsync(_adminUser, _adminPass, UserRole.Administrator);

        // 3. Redirigir al login para que el usuario inicie sesión con su nueva cuenta
        NavManager.NavigateTo("/login", true);
    }

    private void SkipSetup() => NavManager.NavigateTo("/", true);
}
