@page "/settings"
@using pz_server_administrator.Models
@using pz_server_administrator.Services
@using pz_server_administrator.Data.Database.Mods
@inject IConfigurationService ConfigService
@inject ILocalizationService LocService
@inject IToastService ToastService
@inject IPzServerService PzServer
@inject IModDiscoveryService ModDiscovery

<PageTitle>@LocService.Get("Nav.Settings")</PageTitle>

<FluentHeader Style="background-color: transparent; padding: 0;">
    <FluentStack VerticalAlignment="VerticalAlignment.Center" Spacing="3">
        <FluentIcon Value="@(new Icons.Regular.Size24.Settings())" Color="Color.Accent" />
        <FluentLabel Typo="Typography.Header">@LocService.Get("Nav.Settings")</FluentLabel>
    </FluentStack>
</FluentHeader>

<div style="margin-top: 2rem; max-width: 900px;">
    <FluentAccordion>
        @* --- GENERAL: Idioma --- *@
        <FluentAccordionItem Heading="@LocService.Get("Settings.General")" Expanded="true">
            <div slot="start">
                <FluentIcon Value="@(new Icons.Regular.Size20.Globe())" />
            </div>
            <div style="padding: 1rem;">
                <FluentStack Orientation="Orientation.Vertical" Spacing="4">
                    <FluentSelect Label="@LocService.Get("Language.Select")" Items="@_availableLanguages"
                        OptionText="@(i => i.Name)" OptionValue="@(i => i.Code)" @bind-Value="_selectedLanguage"
                    @bind-Value:after="ChangeLanguage" Style="min-width: 250px;" />

                    <p style="opacity: 0.7; font-size: 0.85rem;">@LocService.Get("Settings.LanguageTip")</p>
                </FluentStack>
            </div>
        </FluentAccordionItem>

        @* --- ARCHIVOS DEL SERVIDOR --- *@
        <FluentAccordionItem Heading="@LocService.Get("Settings.ServerFiles")">
            <div slot="start">
                <FluentIcon Value="@(new Icons.Regular.Size20.Folder())" />
            </div>
            <div style="padding: 1rem;">
                <p style="opacity: 0.8; margin-bottom: 1.5rem;">@LocService.Get("Settings.FilePathsTip")</p>

                <FluentGrid Spacing="3">
                    <FluentGridItem xs="12" sm="6">
                        <FluentTextField @bind-Value="_config.AppSettings.ZomboidDirectory"
                            Label="Directorio Zomboid (Zomboid/Server)" Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="6">
                        <FluentTextField @bind-Value="_config.AppSettings.ServerIniPath"
                            Label="Archivo .INI del Servidor" Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="6">
                        <FluentTextField @bind-Value="_config.AppSettings.SandboxVarsPath"
                            Label="Archivo SandboxVars.lua" Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="6">
                        <FluentTextField @bind-Value="_config.AppSettings.SpawnRegionsPath"
                            Label="Archivo SpawnRegions.lua" Style="width: 100%;" />
                    </FluentGridItem>
                </FluentGrid>

                <div style="margin-top: 1.5rem;">
                    <FluentButton IconStart="@(new Icons.Regular.Size20.Search())" OnClick="RunDeepScan"
                        Loading="_isScanning">
                        Escanear automáticamente (Deep Scan)
                    </FluentButton>
                </div>
            </div>
        </FluentAccordionItem>

        @* --- CONTROL RCON --- *@
        <FluentAccordionItem Heading="Conexión RCON">
            <div slot="start">
                <FluentIcon Value="@(new Icons.Regular.Size20.Connector())" />
            </div>
            <div style="padding: 1rem;">
                <FluentGrid Spacing="3">
                    <FluentGridItem xs="12" sm="6">
                        <FluentTextField @bind-Value="_config.AppSettings.Rcon.Host" Label="Host / IP"
                            Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="3">
                        <FluentNumberField @bind-Value="_config.AppSettings.Rcon.Port" Label="Puerto"
                            Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="3">
                        <FluentTextField @bind-Value="_config.AppSettings.Rcon.Password" Label="Contraseña"
                            Type="TextFieldType.Password" Style="width: 100%;" />
                    </FluentGridItem>
                </FluentGrid>
                <p style="opacity: 0.6; font-size: 0.8rem; margin-top: 1rem;">
                    Si dejas estos campos vacíos, la aplicación intentará leerlos automáticamente del archivo .ini
                    configurado arriba.
                </p>
            </div>
        </FluentAccordionItem>

        @* --- IA & COMUNIDAD --- *@
        <FluentAccordionItem Heading="IA & Community Cloud">
            <div slot="start">
                <FluentIcon Value="@(new Icons.Regular.Size20.Wand())" />
            </div>
            <div style="padding: 1rem;">
                <FluentStack Orientation="Orientation.Vertical" Spacing="4">
                    <FluentTextField @bind-Value="_cloudProfile.ApiKey" Label="Gemini API Key" Placeholder="AIza..."
                        Type="TextFieldType.Password" Style="width: 100%;" />

                    <FluentCheckbox @bind-Value="_cloudProfile.AiAutoFixEnabled"
                        Label="Modo Automático (IA aplica cambios sin confirmar)" />

                    <FluentCheckbox @bind-Value="_cloudProfile.CloudSyncEnabled"
                        Label="Sincronizar perfiles con la nube comunitara" />

                    <FluentCheckbox @bind-Value="_cloudProfile.AutoReport"
                        Label="Reportar estadísticas anónimas para mejorar el Agente" />
                </FluentStack>
            </div>
        </FluentAccordionItem>
    </FluentAccordion>

    <div style="margin-top: 2rem; display: flex; gap: 1rem;">
        <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit" OnClick="SaveAllSettings"
            IconStart="@(new Icons.Regular.Size20.Save())">
            @LocService.Get("Generic.Save")
        </FluentButton>
        <FluentButton Appearance="Appearance.Neutral" OnClick="ResetChanges">@LocService.Get("Generic.Cancel")
        </FluentButton>
    </div>
</div>

@code {
    private ZsmConfiguration _config = new();
    private CloudProfile _cloudProfile = new();
    private bool _isScanning;
    private string _selectedLanguage = "es";
    private List<LangOption> _availableLanguages = new();

    protected override async Task OnInitializedAsync()
    {
        _config = ConfigService.GetConfiguration();
        _cloudProfile = await ModDiscovery.GetCloudProfileAsync();
        _selectedLanguage = LocService.CurrentLanguage;

        foreach (var code in LocService.AvailableLanguages)
        {
            var name = await LocService.GetLanguageNameAsync(code);
            _availableLanguages.Add(new LangOption { Code = code, Name = name });
        }
    }

    private async Task ChangeLanguage()
    {
        await LocService.SetLanguage(_selectedLanguage);
        ToastService.ShowSuccess("Idioma cambiado");
    }

    private async Task RunDeepScan()
    {
        _isScanning = true;
        try
        {
            var success = await PzServer.AutoConfigureAsync();
            if (success)
            {
                _config = ConfigService.GetConfiguration(); // Recargar
                ToastService.ShowSuccess("Escaneo profundo completado con éxito.");
            }
            else
            {
                ToastService.ShowWarning("No se encontraron todos los archivos, pero se actualizaron algunos.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error durante el escaneo: {ex.Message}");
        }
        finally
        {
            _isScanning = false;
        }
    }

    private async Task SaveAllSettings()
    {
        try
        {
            await ConfigService.SaveConfigurationAsync(_config);
            await ModDiscovery.UpdateCloudProfileAsync(_cloudProfile);
            ToastService.ShowSuccess(LocService.Get("Settings.SaveSuccess") ?? "Configuración guardada correctamente");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al guardar: {ex.Message}");
        }
    }

    private void ResetChanges()
    {
        _config = ConfigService.GetConfiguration();
        ToastService.ShowInfo("Cambios descartados");
    }

    public class LangOption
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
    }
}
