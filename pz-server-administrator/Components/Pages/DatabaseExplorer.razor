@page "/database"
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.EntityFrameworkCore
@using System.Data
@using pz_server_administrator.Services
@using pz_server_administrator.Data.Database.Players
@using pz_server_administrator.Data.Database.Vehicles
@using pz_server_administrator.Data.Database.ServerTest
@inject IDatabaseContextFactory DatabaseContextFactory
@inject IToastService ToastService
@implements IDisposable

<PageTitle>Database Explorer - Project Zomboid Server Administrator</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="20" Width="100%">
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
            <FluentLabel Typo="Typography.H3">
                <FluentIcon Value="@(new Icons.Regular.Size24.Database())" />
                Explorador de Base de Datos (EF Core)
            </FluentLabel>
            <FluentLabel Typo="Typography.Body">
                Explora y edita directamente las bases de datos SQlite del servidor (Players, Vehicles, ServerTest).
            </FluentLabel>
        </FluentStack>
    </FluentCard>

    <FluentCard>
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
            HorizontalGap="10">
            <FluentIcon Value="@(new Icons.Regular.Size20.Filter())" />
            <FluentTextField Value="@_filterText" @oninput="HandleFilterInput"
                Placeholder="Buscar en todos los campos..." Style="width: 100%;" Immediate="true">
                <FluentIcon Value="@(new Icons.Regular.Size16.Search())" Slot="start" />
            </FluentTextField>
            <FluentButton IconStart="@(new Icons.Regular.Size16.ArrowClockwise())" OnClick="LoadTabData"
                Title="Refrescar" />
        </FluentStack>
    </FluentCard>

    @if (_isBusy)
    {
        <FluentProgressRing />
    }
    else if (!_isConfigured)
    {
        <FluentCard>
            <FluentMessageBar Intent="MessageIntent.Warning">
                El directorio del servidor no está configurado correctamente o no se encontraron los archivos `.db`.
            </FluentMessageBar>
        </FluentCard>
    }
    else
    {
        <FluentTabs @bind-ActiveTabId="activeTabId" OnTabChange="HandleTabChange" Width="100%">
            <FluentTab Id="tab-players" Label="Players DB">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="margin-top: 15px;">
                    <FluentSelect TValue="string" Items="@_playersTables" @bind-Value="@_selectedPlayerTable"
                        Label="Seleccionar Tabla" />

                    @if (_selectedPlayerTable == "NetworkPlayers" && _netPlayers != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_netPlayers" TGridItem="NetworkPlayer" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(p => p.Id)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Username)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Name)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Steamid)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.X)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Y)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.IsDead)" Sortable="true" Title="Dead?" />
                                <TemplateColumn Title="Acciones" Align="Align.Center">
                                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())"
                                        OnClick="@(() => ShowEditDialog(context))" />
                                </TemplateColumn>
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                    else if (_selectedPlayerTable == "LocalPlayers" && _locPlayers != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_locPlayers" TGridItem="LocalPlayer" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(p => p.Id)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Name)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.X)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Y)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.IsDead)" Sortable="true" Title="Dead?" />
                                <TemplateColumn Title="Acciones" Align="Align.Center">
                                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())"
                                        OnClick="@(() => ShowEditDialog(context))" />
                                </TemplateColumn>
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                </FluentStack>
            </FluentTab>

            <FluentTab Id="tab-vehicles" Label="Vehicles DB">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="margin-top: 15px;">
                    <FluentLabel Typo="Typography.H6">Tabla: Vehicles</FluentLabel>
                    @if (_vehicles != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_vehicles" TGridItem="Vehicle" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(v => v.Id)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.X)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Y)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Wx)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Wy)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Worldversion)" Sortable="true" />
                                <TemplateColumn Title="Acciones" Align="Align.Center">
                                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())"
                                        OnClick="@(() => ShowEditDialog(context))" />
                                </TemplateColumn>
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                </FluentStack>
            </FluentTab>

            <FluentTab Id="tab-server" Label="ServerTest DB">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="margin-top: 15px;">
                    <FluentSelect TValue="string" Items="@_serverTables" @bind-Value="@_selectedServerTable"
                        Label="Seleccionar Tabla" />

                    @if (_selectedServerTable == "Whitelist" && _whitelists != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_whitelists" TGridItem="Whitelist" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(w => w.Id)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.Username)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.Steamid)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.Role)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.LastConnection)" Sortable="true" />
                                <TemplateColumn Title="Acciones" Align="Align.Center">
                                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())"
                                        OnClick="@(() => ShowEditDialog(context))" />
                                </TemplateColumn>
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                    else if (_selectedServerTable == "Userlog" && _userlogs != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_userlogs" TGridItem="Userlog" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(u => u.Id)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Username)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Type)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Amount)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Text)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.IssuedBy)" Sortable="true" />
                                <TemplateColumn Title="Acciones" Align="Align.Center">
                                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())"
                                        OnClick="@(() => ShowEditDialog(context))" />
                                </TemplateColumn>
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                    else if (_selectedServerTable == "Tickets" && _tickets != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_tickets" TGridItem="Ticket" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(t => t.Id)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.Author)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.Message)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.Viewed)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.AnsweredId)" Sortable="true" />
                                <TemplateColumn Title="Acciones" Align="Align.Center">
                                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Edit())"
                                        OnClick="@(() => ShowEditDialog(context))" />
                                </TemplateColumn>
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                </FluentStack>
            </FluentTab>
        </FluentTabs>
    }
</FluentStack>

<FluentDialog @bind-Hidden="@_isDialogHidden" Modal="true" TrapFocus="true" Width="500px">
    <FluentDialogHeader>
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
            HorizontalGap="10">
            <FluentIcon Value="@(new Icons.Regular.Size24.Edit())" />
            <FluentLabel Typo="Typography.H4">Editar Registro</FluentLabel>
        </FluentStack>
    </FluentDialogHeader>
    <FluentDialogBody>
        @if (_editingRecord != null)
        {
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="15">
                @if (_editingRecord is NetworkPlayer np)
                {
                    <FluentTextField Value="@np.Id.ToString()" Label="ID (No editable)" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="np.Username" Label="Username" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="np.Name" Label="Nombre" Style="width: 100%" />
                    <FluentTextField @bind-Value="np.Steamid" Label="Steam ID" Style="width: 100%" />
                    <FluentNumberField @bind-Value="np.X" Label="Posición X" Style="width: 100%" />
                    <FluentNumberField @bind-Value="np.Y" Label="Posición Y" Style="width: 100%" />
                    <FluentCheckbox Value="@_boolWrapper" OnChanged="UpdateBoolStatus" Label="¿Está muerto?" />
                }
                else if (_editingRecord is LocalPlayer lp)
                {
                    <FluentTextField Value="@lp.Id.ToString()" Label="ID (No editable)" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="lp.Name" Label="Nombre" Style="width: 100%" />
                    <FluentNumberField @bind-Value="lp.X" Label="Posición X" Style="width: 100%" />
                    <FluentNumberField @bind-Value="lp.Y" Label="Posición Y" Style="width: 100%" />
                    <FluentCheckbox Value="@_boolWrapper" OnChanged="UpdateBoolStatus" Label="¿Está muerto?" />
                }
                else if (_editingRecord is Vehicle ve)
                {
                    <FluentTextField Value="@ve.Id.ToString()" Label="ID (No editable)" ReadOnly Style="width: 100%" />
                    <FluentNumberField @bind-Value="ve.X" Label="Posición X" Style="width: 100%" />
                    <FluentNumberField @bind-Value="ve.Y" Label="Posición Y" Style="width: 100%" />
                    <FluentNumberField @bind-Value="ve.Wx" Label="World X" Style="width: 100%" />
                    <FluentNumberField @bind-Value="ve.Wy" Label="World Y" Style="width: 100%" />
                }
                else if (_editingRecord is Whitelist w)
                {
                    <FluentTextField Value="@w.Id.ToString()" Label="ID (No editable)" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="w.Username" Label="Username" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="w.DisplayName" Label="Nombre Visible" Style="width: 100%" />
                    <FluentTextField @bind-Value="w.Steamid" Label="Steam ID" Style="width: 100%" />
                    <FluentNumberField @bind-Value="w.Role" Label="Rol (Int)" Style="width: 100%" />
                    <FluentTextField @bind-Value="w.Password" Label="Contraseña (Hashed)" Style="width: 100%" />
                }
                else if (_editingRecord is Userlog u)
                {
                    <FluentTextField Value="@u.Id.ToString()" Label="ID (No editable)" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="u.Username" Label="Username" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="u.Type" Label="Tipo" Style="width: 100%" />
                    <FluentNumberField @bind-Value="u.Amount" Label="Cantidad" Style="width: 100%" />
                    <FluentTextArea @bind-Value="u.Text" Label="Texto / Razón" Rows="3" Style="width: 100%" />
                }
                else if (_editingRecord is Ticket t)
                {
                    <FluentTextField Value="@t.Id.ToString()" Label="ID (No editable)" ReadOnly Style="width: 100%" />
                    <FluentTextField @bind-Value="t.Author" Label="Autor" ReadOnly Style="width: 100%" />
                    <FluentTextArea @bind-Value="t.Message" Label="Mensaje" Rows="4" Style="width: 100%" />
                    <FluentCheckbox Value="@_boolWrapper" OnChanged="UpdateBoolStatus" Label="Visto" />
                    <FluentNumberField @bind-Value="t.AnsweredId" Label="ID Respuesta" Style="width: 100%" />
                }
            </FluentStack>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveRecord" Loading="_isSaving">
            Guardar Cambios
        </FluentButton>
        <FluentButton OnClick="@(() => _isDialogHidden = true)">
            Cancelar
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private bool _isBusy = true;
    private bool _isConfigured = false;
    private string activeTabId = "tab-players";
    private string _filterText = "";
    private bool _isDialogHidden = true;
    private object? _editingRecord;
    private bool _isSaving = false;
    private bool _boolWrapper = false;

    private PlayersContext? _playersContext;
    private VehiclesContext? _vehiclesContext;
    private ServerTestContext? _serverContext;

    // Data queryables
    private IQueryable<NetworkPlayer>? _netPlayers;
    private IQueryable<LocalPlayer>? _locPlayers;
    private IQueryable<Vehicle>? _vehicles;
    private IQueryable<Whitelist>? _whitelists;
    private IQueryable<Userlog>? _userlogs;
    private IQueryable<Ticket>? _tickets;

    // Dropdowns
    private List<string> _playersTables = new() { "NetworkPlayers", "LocalPlayers" };
    private string _selectedPlayerTable = "NetworkPlayers";

    private List<string> _serverTables = new() { "Whitelist", "Userlog", "Tickets" };
    private string _selectedServerTable = "Whitelist";

    private PaginationState pagination = new PaginationState { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        _isBusy = true;
        try
        {
            _playersContext = DatabaseContextFactory.CreatePlayersContext();
            _vehiclesContext = DatabaseContextFactory.CreateVehiclesContext();
            _serverContext = DatabaseContextFactory.CreateServerTestContext();

            if (_playersContext != null || _vehiclesContext != null || _serverContext != null)
            {
                _isConfigured = true;
                LoadTabData();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al cargar bases de datos: {ex.Message}");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void HandleTabChange(FluentTab tab)
    {
        LoadTabData();
    }

    private void HandleFilterInput(ChangeEventArgs e)
    {
        _filterText = e.Value?.ToString() ?? "";
        LoadTabData();
    }

    private void UpdateBoolStatus(bool value)
    {
        _boolWrapper = value;
        if (_editingRecord is NetworkPlayer np) np.IsDead = value;
        else if (_editingRecord is LocalPlayer lp) lp.IsDead = value;
        else if (_editingRecord is Ticket t) t.Viewed = value;
    }

    private void LoadTabData()
    {
        var filter = _filterText?.ToLower() ?? "";

        if (activeTabId == "tab-players" && _playersContext != null)
        {
            _netPlayers = _playersContext.NetworkPlayers
            .Where(p => string.IsNullOrEmpty(filter) ||
            (p.Username != null && p.Username.ToLower().Contains(filter)) ||
            (p.Name != null && p.Name.ToLower().Contains(filter)) ||
            (p.Steamid != null && p.Steamid.ToLower().Contains(filter)))
            .AsQueryable();
            _locPlayers = _playersContext.LocalPlayers
            .Where(p => string.IsNullOrEmpty(filter) ||
            (p.Name != null && p.Name.ToLower().Contains(filter)))
            .AsQueryable();
        }
        else if (activeTabId == "tab-vehicles" && _vehiclesContext != null)
        {
            _vehicles = _vehiclesContext.Vehicles
            .Where(v => string.IsNullOrEmpty(filter) || v.Id.ToString().Contains(filter))
            .AsQueryable();
        }
        else if (activeTabId == "tab-server" && _serverContext != null)
        {
            _whitelists = _serverContext.Whitelists
            .Where(w => string.IsNullOrEmpty(filter) ||
            (w.Username != null && w.Username.ToLower().Contains(filter)) ||
            (w.Steamid != null && w.Steamid.ToLower().Contains(filter)) ||
            (w.DisplayName != null && w.DisplayName.ToLower().Contains(filter)))
            .AsQueryable();
            _userlogs = _serverContext.Userlogs
            .Where(u => string.IsNullOrEmpty(filter) ||
            (u.Username != null && u.Username.ToLower().Contains(filter)) ||
            (u.Text != null && u.Text.ToLower().Contains(filter)))
            .AsQueryable();
            _tickets = _serverContext.Tickets
            .Where(t => string.IsNullOrEmpty(filter) ||
            (t.Author != null && t.Author.ToLower().Contains(filter)) ||
            (t.Message != null && t.Message.ToLower().Contains(filter)))
            .AsQueryable();
        }
    }

    private void ShowEditDialog(object record)
    {
        _editingRecord = record;

        // Reset and set wrapper
        _boolWrapper = false;
        if (record is NetworkPlayer np) _boolWrapper = np.IsDead ?? false;
        else if (record is LocalPlayer lp) _boolWrapper = lp.IsDead ?? false;
        else if (record is Ticket t) _boolWrapper = t.Viewed ?? false;

        _isDialogHidden = false;
    }

    private async Task SaveRecord()
    {
        if (_editingRecord == null) return;
        _isSaving = true;
        try
        {
            int changes = 0;
            if (_editingRecord is NetworkPlayer || _editingRecord is LocalPlayer)
                changes = await _playersContext!.SaveChangesAsync();
            else if (_editingRecord is Vehicle)
                changes = await _vehiclesContext!.SaveChangesAsync();
            else if (_editingRecord is Whitelist || _editingRecord is Userlog || _editingRecord is Ticket)
                changes = await _serverContext!.SaveChangesAsync();

            ToastService.ShowSuccess($"Éxito: {changes} cambios guardados.");
            _isDialogHidden = true;
            LoadTabData();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error al guardar: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    public void Dispose()
    {
        _playersContext?.Dispose();
        _vehiclesContext?.Dispose();
        _serverContext?.Dispose();
    }
}
