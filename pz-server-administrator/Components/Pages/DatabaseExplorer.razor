@page "/database"
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.EntityFrameworkCore
@using System.Data
@using pz_server_administrator.Services
@using pz_server_administrator.Models
@using pz_server_administrator.Data.Database.Players
@using pz_server_administrator.Data.Database.Vehicles
@using pz_server_administrator.Data.Database.ServerTest
@inject IDatabaseContextFactory DatabaseContextFactory
@inject IToastService ToastService
@implements IDisposable

<PageTitle>Database Explorer - Project Zomboid Server Administrator</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="20" Width="100%">
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
            <FluentLabel Typo="Typography.H3">
                <FluentIcon Value="@(new Icons.Regular.Size24.Database())" />
                Explorador de Base de Datos (EF Core)
            </FluentLabel>
            <FluentLabel Typo="Typography.Body">
                Explora y controla directamente las bases de datos SQlite del servidor Project Zomboid (Players,
                Vehicles, ServerTest).
            </FluentLabel>
        </FluentStack>
    </FluentCard>

    @if (_isBusy)
    {
        <FluentProgressRing />
    }
    else if (!_isConfigured)
    {
        <FluentCard>
            <FluentMessageBar Intent="MessageIntent.Warning">
                El directorio del servidor no está configurado correctamente o no se encontraron los archivos `.db`.
                Asegúrate de configurar la ruta del servidor en "Ajustes de Servidor".
            </FluentMessageBar>
        </FluentCard>
    }
    else
    {
        <FluentTabs @bind-ActiveTabId="activeTabId" OnTabChange="HandleTabChange" Width="100%">
            <FluentTab Id="tab-players" Label="Players DB">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="margin-top: 15px;">
                    <FluentSelect TValue="string" Items="@_playersTables" @bind-Value="@_selectedPlayerTable"
                        Label="Seleccionar Tabla" />

                    @if (_selectedPlayerTable == "NetworkPlayers" && _netPlayers != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_netPlayers" TGridItem="NetworkPlayer" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(p => p.Id)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Username)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Name)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Steamid)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.X)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Y)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.IsDead)" Sortable="true" Title="Dead?" />
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                    else if (_selectedPlayerTable == "LocalPlayers" && _locPlayers != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_locPlayers" TGridItem="LocalPlayer" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(p => p.Id)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Name)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.X)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.Y)" Sortable="true" />
                                <PropertyColumn Property="@(p => p.IsDead)" Sortable="true" Title="Dead?" />
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                </FluentStack>
            </FluentTab>

            <FluentTab Id="tab-vehicles" Label="Vehicles DB">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="margin-top: 15px;">
                    <FluentLabel Typo="Typography.H6">Tabla: Vehicles</FluentLabel>
                    @if (_vehicles != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_vehicles" TGridItem="Vehicle" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(v => v.Id)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.X)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Y)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Wx)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Wy)" Sortable="true" />
                                <PropertyColumn Property="@(v => v.Worldversion)" Sortable="true" />
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                </FluentStack>
            </FluentTab>

            <FluentTab Id="tab-server" Label="ServerTest DB">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="15" Style="margin-top: 15px;">
                    <FluentSelect TValue="string" Items="@_serverTables" @bind-Value="@_selectedServerTable"
                        Label="Seleccionar Tabla" />

                    @if (_selectedServerTable == "Whitelist" && _whitelists != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_whitelists" TGridItem="Whitelist" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(w => w.Id)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.Username)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.Steamid)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.AuthType)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.Role)" Sortable="true" />
                                <PropertyColumn Property="@(w => w.LastConnection)" Sortable="true" />
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                    else if (_selectedServerTable == "Userlog" && _userlogs != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_userlogs" TGridItem="Userlog" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(u => u.Id)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Username)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Type)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Amount)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.Text)" Sortable="true" />
                                <PropertyColumn Property="@(u => u.IssuedBy)" Sortable="true" />
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                    else if (_selectedServerTable == "Tickets" && _tickets != null)
                    {
                        <div class="grid" style="width: 100%; overflow-x: auto; max-height: 600px;">
                            <FluentDataGrid Items="@_tickets" TGridItem="Ticket" Pagination="@pagination"
                                GenerateHeader="GenerateHeaderOption.Default">
                                <PropertyColumn Property="@(t => t.Id)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.Author)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.Message)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.Viewed)" Sortable="true" />
                                <PropertyColumn Property="@(t => t.AnsweredId)" Sortable="true" />
                            </FluentDataGrid>
                            <FluentPaginator State="@pagination" />
                        </div>
                    }
                </FluentStack>
            </FluentTab>
        </FluentTabs>
    }
</FluentStack>

@code {
    private bool _isBusy = true;
    private bool _isConfigured = false;
    private string activeTabId = "tab-players";

    private PlayersContext? _playersContext;
    private VehiclesContext? _vehiclesContext;
    private ServerTestContext? _serverContext;

    // Data queryables
    private IQueryable<NetworkPlayer>? _netPlayers;
    private IQueryable<LocalPlayer>? _locPlayers;
    private IQueryable<Vehicle>? _vehicles;
    private IQueryable<Whitelist>? _whitelists;
    private IQueryable<Userlog>? _userlogs;
    private IQueryable<Ticket>? _tickets;

    // Dropdowns
    private List<string> _playersTables = new() { "NetworkPlayers", "LocalPlayers" };
    private string _selectedPlayerTable = "NetworkPlayers";

    private List<string> _serverTables = new() { "Whitelist", "Userlog", "Tickets" };
    private string _selectedServerTable = "Whitelist";

    private PaginationState pagination = new PaginationState { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        _isBusy = true;
        try
        {
            _playersContext = DatabaseContextFactory.CreatePlayersContext();
            _vehiclesContext = DatabaseContextFactory.CreateVehiclesContext();
            _serverContext = DatabaseContextFactory.CreateServerTestContext();

            if (_playersContext != null || _vehiclesContext != null || _serverContext != null)
            {
                _isConfigured = true;
                LoadTabData();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error loading databases: {ex.Message}");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void HandleTabChange(FluentTab tab)
    {
        LoadTabData();
    }

    private void LoadTabData()
    {
        if (activeTabId == "tab-players" && _playersContext != null)
        {
            _netPlayers = _playersContext.NetworkPlayers.AsQueryable();
            _locPlayers = _playersContext.LocalPlayers.AsQueryable();
        }
        else if (activeTabId == "tab-vehicles" && _vehiclesContext != null)
        {
            _vehicles = _vehiclesContext.Vehicles.AsQueryable();
        }
        else if (activeTabId == "tab-server" && _serverContext != null)
        {
            _whitelists = _serverContext.Whitelists.AsQueryable();
            _userlogs = _serverContext.Userlogs.AsQueryable();
            _tickets = _serverContext.Tickets.AsQueryable();
        }
    }

    public void Dispose()
    {
        _playersContext?.Dispose();
        _vehiclesContext?.Dispose();
        _serverContext?.Dispose();
    }
}
